{
    "openapi": "3.0.1",
    "info": {
        "title": "Offers API",
        "description": "The API for the offer resource",
        "termsOfService": "https://api.bol.com/retailer/public/Retailer-API/legal/terms-of-service.html",
        "contact": {
            "name": "developers.bol.com",
            "url": "https://developers.bol.com"
        },
        "version": "11.3.0",
        "x-logo": {
            "url": "https://api.bol.com/retailer/public/Retailer-API/_images/bolcom_logo.png",
            "altText": "bol. logo"
        }
    },
    "security": [
        {
            "OAuth2": []
        }
    ],
    "tags": [
        {
            "name": "Offers"
        }
    ],
    "paths": {
        "/retailer/offers": {
            "get": {
                "tags": [
                    "Offers"
                ],
                "operationId": "get-offers",
                "x-bol-scopes": [
                    "retailer",
                    "offers.read",
                    "offers.manage"
                ],
                "summary": "Get offers",
                "parameters": [
                    {
                        "name": "offer-ids",
                        "in": "query",
                        "description": "List of offer ids to search for.",
                        "required": false,
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "format": "uuid"
                            }
                        }
                    },
                    {
                        "name": "eans",
                        "in": "query",
                        "description": "List of eans to search for",
                        "required": false,
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    {
                        "name": "reference",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "required": false,
                        "description": "Filter offers by reference."
                    },
                    {
                        "name": "for-sale",
                        "in": "query",
                        "description": "Filter offers based on whether they are for sale.",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": null
                        }
                    },
                    {
                        "name": "last-modified-date-time",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "format": "date-time",
                            "example": 1542184481
                        },
                        "required": false,
                        "description": "Filter offers updated since the specified date-time. The timestamp should be in ISO 8601 format (UTC)."
                    },
                    {
                        "name": "page-size",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "format": "int32",
                            "minimum": 1,
                            "maximum": 100,
                            "description": "Number of offers per page."
                        },
                        "required": false,
                        "description": "The number of offers per page."
                    },
                    {
                        "name": "cursor",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "description": "Cursor token used to retrieve the next page of results."
                        },
                        "required": false,
                        "description": "Cursor token used to retrieve the next page of results."
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The request was successfully processed, returning a paginated list of offers.",
                        "content": {
                            "application/vnd.retailer.v11+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/OfferListResponse"
                                }
                            }
                        }
                    }
                },
                "description": "Get offers"
            },
            "post": {
                "tags": [
                    "Offers"
                ],
                "operationId": "create-offer",
                "x-bol-scopes": [
                    "retailer",
                    "offers.manage"
                ],
                "summary": "Create a new offer",
                "requestBody": {
                    "content": {
                        "application/vnd.retailer.v11+json": {
                            "schema": {
                                "$ref": "#/components/schemas/OffersCreateOfferRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Offer is created",
                        "content": {
                            "application/vnd.retailer.v11+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/OffersRetailerOffer"
                                }
                            }
                        }
                    }
                },
                "description": "Create a new offer"
            }
        },
        "/retailer/offers/{offer-id}": {
            "get": {
                "tags": [
                    "Offers"
                ],
                "operationId": "get-offer",
                "x-bol-scopes": [
                    "retailer",
                    "offers.read",
                    "offers.manage"
                ],
                "summary": "Get an offer by offer id",
                "parameters": [
                    {
                        "in": "path",
                        "name": "offer-id",
                        "required": true,
                        "description": "The unique identifier of the offer.",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The offer was successfully retrieved.",
                        "content": {
                            "application/vnd.retailer.v11+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/OfferResponse"
                                }
                            }
                        }
                    }
                },
                "description": "Get an offer by offer id"
            },
            "delete": {
                "tags": [
                    "Offers"
                ],
                "summary": "Delete offer by id",
                "operationId": "delete-offer",
                "x-bol-scopes": [
                    "retailer",
                    "offers.manage"
                ],
                "parameters": [
                    {
                        "name": "offer-id",
                        "in": "path",
                        "required": true,
                        "description": "The unique identifier of the offer to be deleted.",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Offer was deleted successfully.",
                        "content": {
                            "application/vnd.retailer.v11+json": []
                        }
                    }
                },
                "description": "Delete offer by id"
            },
            "patch": {
                "tags": [
                    "Offers"
                ],
                "summary": "Update an offer",
                "operationId": "update-offer",
                "x-bol-scopes": [
                    "retailer",
                    "offers.manage"
                ],
                "parameters": [
                    {
                        "name": "offer-id",
                        "in": "path",
                        "required": true,
                        "description": "The unique identifier of the offer to be updated.",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/vnd.retailer.v11+json": {
                            "schema": {
                                "$ref": "#/components/schemas/PatchOfferRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Offer was updated successfully.",
                        "content": {
                            "application/vnd.retailer.v11+json": []
                        }
                    }
                },
                "description": "Update an offer"
            }
        },
        "/retailer/offers/{offer-id}/not-for-sale-reasons": {
            "get": {
                "tags": [
                    "Offers"
                ],
                "operationId": "get-not-for-sale-reasons",
                "x-bol-scopes": [
                    "retailer",
                    "offers.read",
                    "offers.manage"
                ],
                "summary": "Get not for sale reasons for an offer by offer id",
                "parameters": [
                    {
                        "in": "path",
                        "name": "offer-id",
                        "required": true,
                        "description": "The unique identifier of the offer.",
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The request was successfully processed, returning offer feedbacks.",
                        "content": {
                            "application/vnd.retailer.v11+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotForSaleReasons"
                                },
                                "example": {
                                    "offerId": "123456789",
                                    "countries": [
                                        {
                                            "countryCode": "NL",
                                            "reasons": [
                                                {
                                                    "category": "PRICE",
                                                    "code": "4000-1",
                                                    "description": "Price too high"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                "description": "Get not for sale reasons for an offer by offer id"
            }
        }
    },
    "components": {
        "schemas": {
            "PatchOfferRequest": {
                "type": "object",
                "properties": {
                    "unknownProductTitle": {
                        "minLength": 0,
                        "maxLength": 500,
                        "type": "string",
                        "description": "If the product is not recognized by bol, the retailer may use this field to provide a custom title for identification. Note that, in case the product is known to bol, the unknown product title will not be stored.",
                        "example": "unknown title"
                    },
                    "economicOperatorId": {
                        "type": "string",
                        "description": "An identifier referring to the Economic operator entity (manufacturer, authorized party, importer, distributor or other natural person or legal entity for whom the obligations apply with regards to the manufacturing, or making available on the market of the product in line with the applicable EU laws.",
                        "example": "0c6573a2-a80c-48b7-a03e-d5939f1173fa"
                    },
                    "onHoldByRetailer": {
                        "type": "boolean",
                        "default": false,
                        "description": "Specifies whether the offer should be listed for sale on bol. Useful for temporarily suspending visibility without deletion.",
                        "example": true
                    },
                    "reference": {
                        "minLength": 0,
                        "maxLength": 100,
                        "type": "string",
                        "description": "A custom reference string defined by the retailer to help identify and correlate the offer with internal systems.",
                        "example": "AX1234"
                    },
                    "countryAvailabilities": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CreateCountryAvailability"
                        }
                    },
                    "pricing": {
                        "$ref": "#/components/schemas/OffersPricing"
                    },
                    "fulfilment": {
                        "$ref": "#/components/schemas/OffersFulfilment"
                    },
                    "stock": {
                        "$ref": "#/components/schemas/UpdateStock"
                    }
                }
            },
            "CreateStock": {
                "type": "object",
                "required": [
                    "amount",
                    "managedByRetailer"
                ],
                "properties": {
                    "amount": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The quantity of the product currently available in the retailer's warehouse for fulfillment.",
                        "default": 0
                    },
                    "managedByRetailer": {
                        "type": "boolean",
                        "description": "Configures whether the retailer manages the stock levels or that bol should calculate the corrected stock based on actual open orders. In case the configuration is set to 'false', all open orders are used to calculate the corrected stock. In case the configuration is set to true, only orders that are placed after the last offer update are taken into account."
                    }
                }
            },
            "UpdateStock": {
                "type": "object",
                "properties": {
                    "amount": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The quantity of the product currently available in the retailer's warehouse for fulfillment."
                    },
                    "managedByRetailer": {
                        "type": "boolean",
                        "description": "Configures whether the retailer manages the stock levels or that bol should calculate the corrected stock based on actual open orders. In case the configuration is set to 'false', all open orders are used to calculate the corrected stock. In case the configuration is set to true, only orders that are placed after the last offer update are taken into account."
                    }
                }
            },
            "Page": {
                "type": "object",
                "properties": {
                    "pageSize": {
                        "nullable": true,
                        "format": "int32",
                        "minimum": 25,
                        "maximum": 100,
                        "description": "Number of items per page, with a maximum limit of 100",
                        "type": "integer"
                    },
                    "nextCursor": {
                        "description": "Cursor token used to retrieve the next page of results",
                        "type": "string",
                        "nullable": true
                    }
                }
            },
            "OfferListResponse": {
                "type": "object",
                "required": [
                    "offers",
                    "page"
                ],
                "properties": {
                    "offers": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/OfferResponse"
                        }
                    },
                    "page": {
                        "$ref": "#/components/schemas/Page"
                    }
                }
            },
            "OfferResponse": {
                "required": [
                    "offerId",
                    "lastModifiedDateTime",
                    "onHoldByRetailer",
                    "condition",
                    "pricing",
                    "fulfilment"
                ],
                "properties": {
                    "offerId": {
                        "type": "string",
                        "format": "uuid",
                        "description": "A globally unique identifier assigned to each offer, used for tracking and referencing within the system.",
                        "example": "6ff736b5-cdd0-4150-8c67-78269ee986f5"
                    },
                    "ean": {
                        "type": "string",
                        "description": "The European Article Number (EAN) uniquely identifying the product, used for inventory and cataloging purposes. Note that in case an ISBN is provided, it will be replaced with the actual EAN belonging to this ISBN.",
                        "example": "0000007740404"
                    },
                    "lastModifiedDateTime": {
                        "type": "string",
                        "description": "The date time this offer was last modified by either bol or the partner itself."
                    },
                    "reference": {
                        "minLength": 0,
                        "maxLength": 100,
                        "type": "string",
                        "description": "A custom reference string defined by the retailer to help identify and correlate the offer with internal systems.",
                        "example": "AX1234"
                    },
                    "onHoldByRetailer": {
                        "type": "boolean",
                        "description": "Specifies whether the offer should be listed for sale on bol. Useful for temporarily suspending visibility without deletion.",
                        "default": false
                    },
                    "economicOperatorId": {
                        "type": "string",
                        "description": "An identifier referring to the Economic operator entity (manufacturer, authorized party, importer, distributor or other natural person or legal entity for whom the obligations apply with regards to the manufacturing, or making available on the market of the product in line with the applicable EU laws.",
                        "example": "0c6573a2-a80c-48b7-a03e-d5939f1173fa"
                    },
                    "unknownProductTitle": {
                        "minLength": 0,
                        "maxLength": 500,
                        "type": "string",
                        "description": "If the product is not recognized by bol, the retailer may use this field to provide a custom title for identification. Note that, in case the product is known to bol, the unknown product title will not be stored."
                    },
                    "stock": {
                        "$ref": "#/components/schemas/Stock"
                    },
                    "countryAvailabilities": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CountryAvailability"
                        }
                    },
                    "condition": {
                        "$ref": "#/components/schemas/OffersCondition"
                    },
                    "product": {
                        "$ref": "#/components/schemas/OffersProduct"
                    },
                    "pricing": {
                        "$ref": "#/components/schemas/OffersPricing"
                    },
                    "fulfilment": {
                        "$ref": "#/components/schemas/OffersFulfilment"
                    }
                },
                "type": "object"
            },
            "NotForSaleReasons": {
                "type": "object",
                "required": [
                    "offerId"
                ],
                "properties": {
                    "offerId": {
                        "type": "string",
                        "format": "uuid",
                        "description": "The unique identifier of the offer."
                    },
                    "countries": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/NotForSaleReasonsCountry"
                        }
                    }
                }
            },
            "NotForSaleReasonsCountry": {
                "type": "object",
                "required": [
                    "countryCode"
                ],
                "properties": {
                    "countryCode": {
                        "type": "string",
                        "description": "The country that applies to the offer.",
                        "enum": [
                            "NL",
                            "BE"
                        ]
                    },
                    "reasons": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Reason"
                        }
                    }
                }
            },
            "Reason": {
                "type": "object",
                "properties": {
                    "category": {
                        "type": "string",
                        "enum": [
                            "CONTENT",
                            "PRICE",
                            "STOCK",
                            "SHOP_STATUS",
                            "SELLING_RIGHTS",
                            "ACCOUNT_RIGHTS",
                            "ON_HOLD",
                            "ASSORTMENT_POLICY",
                            "OFFER"
                        ]
                    },
                    "code": {
                        "type": "string",
                        "example": "4004-2",
                        "description": "Unique reason code"
                    },
                    "description": {
                        "type": "string",
                        "example": "For this product essential product information is missing",
                        "description": "A description explaining the reason why this offer is marked as offline."
                    },
                    "missingAttributes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MissingAttribute"
                        }
                    }
                }
            },
            "MissingAttribute": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Title",
                        "description": "Name of the attribute that is missing"
                    }
                }
            },
            "Stock": {
                "type": "object",
                "properties": {
                    "amount": {
                        "type": "integer",
                        "format": "int32",
                        "default": 0,
                        "description": "The amount of stock available for the specified product present in the retailers warehouse. Note that this should not be the FBB stock."
                    },
                    "correctedStock": {
                        "type": "integer",
                        "description": "The available stock after accounting for open and processed orders, based on retailer provided inventory data. Once this value reaches zero the offer becomes unavailable for sale on the web shop.",
                        "format": "int32"
                    },
                    "managedByRetailer": {
                        "type": "boolean",
                        "description": "Determines if stock levels are manually managed by the retailer or automatically adjusted based on open orders."
                    }
                }
            },
            "CountryAvailability": {
                "type": "object",
                "required": [
                    "countryCode"
                ],
                "properties": {
                    "countryCode": {
                        "type": "string",
                        "description": "The country that applies to the offer.",
                        "enum": [
                            "NL",
                            "BE"
                        ]
                    },
                    "forSale": {
                        "type": "boolean",
                        "description": "Specifies whether the offer should be listed for sale on bol."
                    }
                }
            },
            "CreateCountryAvailability": {
                "type": "object",
                "required": [
                    "countryCode"
                ],
                "properties": {
                    "countryCode": {
                        "type": "string",
                        "description": "The country that applies to the offer.",
                        "enum": [
                            "NL",
                            "BE"
                        ]
                    }
                }
            },
            "PricingBundlePrices": {
                "type": "object",
                "required": [
                    "quantity",
                    "unitPrice"
                ],
                "properties": {
                    "quantity": {
                        "type": "integer",
                        "format": "int32",
                        "description": "The minimum quantity a customer must order in order to receive a discount. The array must contain at least one element with a value of 1. If multiple values are provided, they must be in strictly increasing order.",
                        "example": 1
                    },
                    "unitPrice": {
                        "type": "number",
                        "minimum": 1,
                        "maximum": 9999,
                        "description": "The unit price including VAT, applicable when the customer orders at least the corresponding minimum quantity. If multiple prices are provided, they must be listed in strictly decreasing order, matching the increasing order of the associated quantity thresholds.",
                        "example": 9.99
                    }
                }
            },
            "FulfilmentDeliveryPromise": {
                "type": "object",
                "description": "Specifies the expected delivery timeframe for the offer. This value will only be used in combination with fulfilmentMethod 'FBR'.",
                "required": [
                    "minimumDaysToCustomer",
                    "maximumDaysToCustomer"
                ],
                "properties": {
                    "minimumDaysToCustomer": {
                        "type": "integer",
                        "format": "int32",
                        "example": 0,
                        "description": "The minimum amount of days it takes to deliver this item to the customer."
                    },
                    "maximumDaysToCustomer": {
                        "type": "integer",
                        "format": "int32",
                        "example": 1,
                        "description": "The maximum amount of days it takes to deliver this item to the customer."
                    },
                    "ultimateOrderTime": {
                        "type": "string",
                        "example": "14:00",
                        "description": "The ultimate order time the customer needs to place an order on the bol marketplace for next day delivery. If the order is placed after this time, the delivery promise will include one additional day."
                    }
                }
            },
            "OffersCondition": {
                "type": "object",
                "properties": {
                    "category": {
                        "type": "string",
                        "enum": [
                            "NEW",
                            "SECONDHAND",
                            "REFURBISHED"
                        ]
                    },
                    "state": {
                        "type": "string",
                        "enum": [
                            "AS_NEW",
                            "GOOD",
                            "REASONABLE",
                            "MODERATE"
                        ]
                    },
                    "comment": {
                        "type": "string",
                        "description": "The description of the condition of the product. Only allowed if name is not NEW and may not contain e-mail addresses.",
                        "example": "slightly used"
                    },
                    "grade": {
                        "type": "string",
                        "enum": [
                            "A",
                            "B",
                            "C"
                        ]
                    },
                    "margin": {
                        "type": "boolean",
                        "description": "Indicates if there is a margin adjustment due to the condition.",
                        "example": true
                    }
                }
            },
            "OffersCreateOfferRequest": {
                "required": [
                    "condition",
                    "pricing",
                    "ean",
                    "fulfilment"
                ],
                "type": "object",
                "properties": {
                    "ean": {
                        "type": "string",
                        "description": "The European Article Number (EAN) uniquely identifying the product, used for inventory and cataloging purposes. Note that in case an ISBN is provided, it will be replaced with the actual EAN belonging to this ISBN.",
                        "example": "0000007740404"
                    },
                    "unknownProductTitle": {
                        "minLength": 0,
                        "maxLength": 500,
                        "type": "string",
                        "description": "If the product is not recognized by bol, the retailer may use this field to provide a custom title for identification. Note that, in case the product is known to bol, the unknown product title will not be stored.",
                        "example": "unknown title"
                    },
                    "economicOperatorId": {
                        "type": "string",
                        "description": "An identifier referring to the Economic operator entity (manufacturer, authorized party, importer, distributor or other natural person or legal entity for whom the obligations apply with regards to the manufacturing, or making available on the market of the product in line with the applicable EU laws.",
                        "example": "0c6573a2-a80c-48b7-a03e-d5929f1173ff"
                    },
                    "reference": {
                        "minLength": 0,
                        "maxLength": 100,
                        "type": "string",
                        "description": "A custom reference string defined by the retailer to help identify and correlate the offer with internal systems.",
                        "example": "AX1234"
                    },
                    "onHoldByRetailer": {
                        "type": "boolean",
                        "default": false,
                        "description": "Specifies whether the offer should be listed for sale on bol. Useful for temporarily suspending visibility without deletion.",
                        "example": true
                    },
                    "condition": {
                        "$ref": "#/components/schemas/OffersCondition"
                    },
                    "pricing": {
                        "$ref": "#/components/schemas/OffersPricing"
                    },
                    "countryAvailabilities": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CreateCountryAvailability"
                        }
                    },
                    "fulfilment": {
                        "$ref": "#/components/schemas/OffersFulfilment"
                    },
                    "stock": {
                        "$ref": "#/components/schemas/CreateStock"
                    }
                }
            },
            "OffersFulfilment": {
                "type": "object",
                "description": "The fulfilment method. Fulfilled by the retailer (FBR) or fulfilled by bol (FBB)",
                "required": [
                    "method"
                ],
                "properties": {
                    "method": {
                        "type": "string",
                        "enum": [
                            "FBR",
                            "FBB"
                        ]
                    },
                    "schedule": {
                        "type": "string",
                        "enum": [
                            "BOL_DELIVERY_PROMISE",
                            "MY_DELIVERY_PROMISE",
                            "SHIPPING_VIA_BOL"
                        ]
                    },
                    "deliveryPromise": {
                        "$ref": "#/components/schemas/FulfilmentDeliveryPromise"
                    }
                }
            },
            "OffersPricing": {
                "type": "object",
                "required": [
                    "bundlePrices"
                ],
                "properties": {
                    "bundlePrices": {
                        "type": "array",
                        "description": "A set of prices (containing a quantity and selling price) that apply to this offer.",
                        "items": {
                            "$ref": "#/components/schemas/PricingBundlePrices"
                        }
                    }
                }
            },
            "OffersProduct": {
                "type": "object",
                "properties": {
                    "bolProductId": {
                        "type": "string",
                        "description": "Identifier of the product specific to bol site.",
                        "example": "9200000045327288"
                    }
                }
            },
